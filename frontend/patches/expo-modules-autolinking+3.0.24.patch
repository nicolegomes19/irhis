@@ -0,0 +1,28 @@
+package expo.modules.plugin
+
+import java.io.File
+import java.util.Properties
+
+/**
+ * Resolves the Node.js executable path.
+ * Android Studio doesn't inherit the shell PATH, so we read from local.properties.
+ */
+object NodePath {
+  /**
+   * Get the Node.js executable path for the given project root.
+   * Reads node.executable from local.properties (android directory).
+   * Falls back to "node" if not configured.
+   */
+  fun resolve(androidDir: File): String {
+    val localPropertiesFile = File(androidDir, "local.properties")
+    if (!localPropertiesFile.exists()) return "node"
+
+    return try {
+      localPropertiesFile.inputStream().use { input ->
+        Properties().apply { load(input) }.getProperty("node.executable") ?: "node"
+      }
+    } catch (_: Exception) {
+      "node"
+    }
+  }
+}
